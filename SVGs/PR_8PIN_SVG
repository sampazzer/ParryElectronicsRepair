<svg width="110" height="110" viewBox="0 0 110 110" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@700&amp;display=swap');
      
      .silk-logo { 
        fill: #ffffff; 
        font-family: 'Space Grotesk', sans-serif; 
        font-weight: 700; 
        text-anchor: middle;
      }
      .silk-border { fill: none; stroke: #ffffff; stroke-width: 2.5; }
      .pin { fill: #ffffff; }
    </style>
    
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0f766e; stop-opacity:1" />
      <stop offset="100%" style="stop-color:#2563eb; stop-opacity:1" />
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="110" height="110" rx="8" ry="8" fill="url(#bgGradient)"/>
  
  <!-- Stylized Chip Body -->
  <rect x="20" y="20" width="70" height="70" rx="4" ry="4" class="silk-border"/>

  <!-- Pins (Centered vertically with 6px gaps) -->
  <rect x="15" y="30" width="5" height="8" class="pin"/>
  <rect x="15" y="44" width="5" height="8" class="pin"/>
  <rect x="15" y="58" width="5" height="8" class="pin"/>
  <rect x="15" y="72" width="5" height="8" class="pin"/>

  <rect x="90" y="30" width="5" height="8" class="pin"/>
  <rect x="90" y="44" width="5" height="8" class="pin"/>
  <rect x="90" y="58" width="5" height="8" class="pin"/>
  <rect x="90" y="72" width="5" height="8" class="pin"/>

  <!-- "PR" Text -->
  <text x="55" y="68" font-size="35" class="silk-logo">PR</text>
  
  <!-- Pin 1 indicator -->
  <circle cx="31" cy="31" r="4" fill="#ffffff"/>
</svg>
